# Ollama
RUSS_OLLAMA_BASE_URL=http://localhost:11434
RUSS_LLM_MODEL=llama3.2
RUSS_EMBEDDING_MODEL=nomic-embed-text
RUSS_GUARD_MODEL=llama-guard3:1b
RUSS_RERANKER_MODEL=BAAI/bge-reranker-base

# Chunking
RUSS_CHUNK_SIZE=1000
RUSS_CHUNK_OVERLAP=100

# Retrieval
RUSS_SEMANTIC_WEIGHT=0.7
RUSS_BM25_WEIGHT=0.3
RUSS_RETRIEVAL_K=20
RUSS_RERANK_TOP_N=5

# Paths
RUSS_CHROMADB_PATH=./data/chromadb
RUSS_UPLOADS_PATH=./data/uploads

# PDF Parsing
RUSS_PDF_PARSER=marker
RUSS_MAX_FILE_SIZE_MB=100
